<Window x:Class="AIGuard.AdminConsole.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ulti Guard Admin Console"
        Width="1120"
        Height="720"
        MinWidth="920"
        MinHeight="620"
        WindowStartupLocation="CenterScreen">
  
  <Window.Background>
    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#0B132B" Offset="0" />
      <GradientStop Color="#1C2541" Offset="1" />
    </LinearGradientBrush>
  </Window.Background>

  <Window.Resources>
    <!-- Card Style -->
    <Style x:Key="CardStyle" TargetType="Border">
      <Setter Property="Background" Value="#1E293B" />
      <Setter Property="BorderBrush" Value="#334155" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="Padding" Value="20" />
      <Setter Property="Margin" Value="0,0,0,18" />
    </Style>

    <!-- ToggleButton Style for ComboBox -->
    <Style x:Key="ComboBoxToggleButtonStyle" TargetType="ToggleButton">
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ToggleButton">
            <Border x:Name="templateRoot" 
                    Background="{TemplateBinding Background}" 
                    BorderBrush="{TemplateBinding BorderBrush}" 
                    BorderThickness="{TemplateBinding BorderThickness}" 
                    CornerRadius="8" 
                    SnapsToDevicePixels="True">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="34" />
                </Grid.ColumnDefinitions>
                <!-- Dropdown Arrow -->
                <Path x:Name="Arrow" 
                      Grid.Column="1" 
                      Data="M 0 0 L 4 4 L 8 0 Z" 
                      Fill="#94A3B8" 
                      HorizontalAlignment="Center" 
                      VerticalAlignment="Center" />
              </Grid>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="templateRoot" Property="Background" Value="#334155" />
                <Setter TargetName="templateRoot" Property="BorderBrush" Value="#FF6B35" />
                <Setter TargetName="Arrow" Property="Fill" Value="White" />
              </Trigger>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="templateRoot" Property="Background" Value="#0F172A" />
                <Setter TargetName="templateRoot" Property="BorderBrush" Value="#FF6B35" />
                <Setter TargetName="Arrow" Property="Fill" Value="#FF6B35" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ComboBox Premium Theme -->
    <Style TargetType="ComboBox">
      <Setter Property="Background" Value="#1E293B" />
      <Setter Property="Foreground" Value="#F1F5F9" />
      <Setter Property="BorderBrush" Value="#475569" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="12,8" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBox">
            <Grid x:Name="templateRoot" SnapsToDevicePixels="True">
              <!-- ToggleButton provides the background and the dropdown arrow -->
              <ToggleButton Name="toggleButton" 
                            Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}" 
                            Style="{StaticResource ComboBoxToggleButtonStyle}" 
                            IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" 
                            ClickMode="Press" />
              
              <!-- ContentPresenter displays the selected item, offset from the right dropdown arrow button -->
              <ContentPresenter Name="contentPresenter" 
                                Content="{TemplateBinding SelectionBoxItem}" 
                                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" 
                                ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" 
                                Margin="{TemplateBinding Padding}" 
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" 
                                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                IsHitTestVisible="False" />
              
              <!-- Popup displaying the dropdown items -->
              <Popup Name="PART_Popup" 
                     AllowsTransparency="True" 
                     Placement="Bottom" 
                     IsOpen="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" 
                     PopupAnimation="Slide">
                <Border Name="dropDownBorder" 
                        Background="#1E293B" 
                        BorderBrush="#475569" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        MinWidth="{Binding ElementName=templateRoot, Path=ActualWidth}" 
                        MaxHeight="{TemplateBinding MaxDropDownHeight}" 
                        Margin="0,4,0,4">
                  <ScrollViewer Name="DropDownScrollViewer">
                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" 
                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                  </ScrollViewer>
                </Border>
              </Popup>
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="HasItems" Value="False">
                <Setter TargetName="dropDownBorder" Property="Height" Value="95" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Premium ComboBoxItem Style -->
    <Style TargetType="ComboBoxItem">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#F1F5F9" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBoxItem">
            <Border Name="Border" 
                    Background="{TemplateBinding Background}" 
                    Padding="{TemplateBinding Padding}" 
                    CornerRadius="4">
              <ContentPresenter />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Border" Property="Background" Value="#FF6B35" />
                <Setter Property="Foreground" Value="White" />
              </Trigger>
              <Trigger Property="IsHighlighted" Value="True">
                <Setter TargetName="Border" Property="Background" Value="#FF6B35" />
                <Setter Property="Foreground" Value="White" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ListBox Premium Theme -->
    <Style TargetType="ListBox">
      <Setter Property="Background" Value="#0F172A" />
      <Setter Property="Foreground" Value="#F1F5F9" />
      <Setter Property="BorderBrush" Value="#334155" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="6" />
      <Style.Resources>
        <Style TargetType="ListBoxItem">
          <Setter Property="Background" Value="Transparent" />
          <Setter Property="Padding" Value="10,8" />
          <Setter Property="Margin" Value="0,2" />
          <Setter Property="BorderThickness" Value="0" />
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="ListBoxItem">
                <Border Name="Border" 
                        Background="{TemplateBinding Background}" 
                        Padding="{TemplateBinding Padding}" 
                        CornerRadius="8">
                  <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                </Border>
                <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="Background" Value="#334155" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                  </Trigger>
                  <Trigger Property="IsSelected" Value="True">
                    <Setter TargetName="Border" Property="Background" Value="#FF6B35" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                  </Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Style>
      </Style.Resources>
    </Style>

    <!-- Premium Button Styles -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="#FF6B35" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Padding" Value="14,8" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Name="Border" 
                    Background="{TemplateBinding Background}" 
                    CornerRadius="8" 
                    Padding="{TemplateBinding Padding}"
                    SnapsToDevicePixels="True">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Border" Property="Background" Value="#FF8254" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Border" Property="Background" Value="#E0531E" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Border" Property="Background" Value="#475569" />
                <Setter Property="Foreground" Value="#94A3B8" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="Button">
      <Setter Property="Background" Value="#334155" />
      <Setter Property="Foreground" Value="#E2E8F0" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Padding" Value="14,8" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Name="Border" 
                    Background="{TemplateBinding Background}" 
                    CornerRadius="8" 
                    Padding="{TemplateBinding Padding}"
                    SnapsToDevicePixels="True">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Border" Property="Background" Value="#475569" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Border" Property="Background" Value="#1E293B" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Border" Property="Background" Value="#1E293B" />
                <Setter Property="Foreground" Value="#64748B" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Elegant TextBox Style -->
    <Style TargetType="TextBox">
      <Setter Property="Background" Value="#0F172A" />
      <Setter Property="Foreground" Value="#F8FAFC" />
      <Setter Property="BorderBrush" Value="#475569" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="12,8" />
      <Setter Property="CaretBrush" Value="#FF6B35" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Border Name="Border" 
                    Background="{TemplateBinding Background}" 
                    BorderBrush="{TemplateBinding BorderBrush}" 
                    BorderThickness="{TemplateBinding BorderThickness}" 
                    CornerRadius="8">
              <ScrollViewer Name="PART_ContentHost" Focusable="False" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsFocused" Value="True">
                <Setter TargetName="Border" Property="BorderBrush" Value="#FF6B35" />
                <Setter Property="BorderThickness" Value="1.5" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Border" Property="BorderBrush" Value="#64748B" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="SwitchCheckBoxStyle" TargetType="CheckBox">
      <Setter Property="Foreground" Value="#F8FAFC" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="CheckBox">
            <Grid SnapsToDevicePixels="True">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <Border x:Name="SwitchTrack"
                      Width="48"
                      Height="28"
                      Background="#334155"
                      BorderBrush="#475569"
                      BorderThickness="1"
                      CornerRadius="14"
                      VerticalAlignment="Center">
                <Grid Margin="3">
                  <Ellipse x:Name="SwitchThumb"
                           Width="20"
                           Height="20"
                           Fill="#F8FAFC"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center" />
                </Grid>
              </Border>

              <ContentPresenter Grid.Column="2"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True" />
            </Grid>

            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="#64748B" />
              </Trigger>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="SwitchTrack" Property="Background" Value="#FF6B35" />
                <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="#FF6B35" />
                <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="SwitchTrack" Property="Background" Value="#1E293B" />
                <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="#334155" />
                <Setter TargetName="SwitchThumb" Property="Fill" Value="#94A3B8" />
                <Setter Property="Foreground" Value="#64748B" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PiiRadioButtonStyle" TargetType="RadioButton">
      <Setter Property="Background" Value="#F8FAFC" />
      <Setter Property="Foreground" Value="#1E293B" />
      <Setter Property="BorderBrush" Value="#E2E8F0" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Padding" Value="16,14" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RadioButton">
            <Border Name="Border" 
                    Background="{TemplateBinding Background}" 
                    BorderBrush="{TemplateBinding BorderBrush}" 
                    BorderThickness="{TemplateBinding BorderThickness}" 
                    CornerRadius="8" 
                    Padding="{TemplateBinding Padding}"
                    SnapsToDevicePixels="True">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Border" Property="Background" Value="#F1F5F9" />
                <Setter TargetName="Border" Property="BorderBrush" Value="#94A3B8" />
              </Trigger>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Border" Property="Background" Value="#FFF0EB" />
                <Setter TargetName="Border" Property="BorderBrush" Value="#FF6B35" />
                <Setter TargetName="Border" Property="BorderThickness" Value="1.5" />
                <Setter Property="Foreground" Value="#FF6B35" />
                <Setter Property="FontWeight" Value="Bold" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Border" Property="Background" Value="#E2E8F0" />
                <Setter TargetName="Border" Property="BorderBrush" Value="#E2E8F0" />
                <Setter Property="Foreground" Value="#94A3B8" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Header Panel -->
    <Border Grid.Row="0"
            Background="#0F172A"
            BorderBrush="#334155"
            BorderThickness="1"
            CornerRadius="16"
            Padding="24"
            Margin="0,0,0,18">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Image x:Name="LogoImage"
               Width="140"
               Height="64"
               Margin="0,0,22,0"
               Stretch="Uniform" />

        <StackPanel Grid.Column="1">
          <TextBlock Text="TECHHEIGHTS · ENTERPRISE CONTROL"
                     Foreground="#FF6B35"
                     FontWeight="SemiBold"
                     FontSize="12" />
          <TextBlock Text="Ulti Guard Admin Console"
                     Foreground="White"
                     FontWeight="SemiBold"
                     FontSize="28"
                     Margin="0,6,0,0" />
          <TextBlock Text="Manage blocked providers, refresh enterprise browser policy, and keep Claude-only protection enforced without exposing raw config edits to end users."
                     Foreground="#94A3B8"
                     TextWrapping="Wrap"
                     Margin="0,8,0,0" />
        </StackPanel>

        <StackPanel Grid.Column="2"
                    MaxWidth="320"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="18,0,0,0">
          <Border Background="#FF6B35"
                  CornerRadius="999"
                  Padding="14,8"
                  HorizontalAlignment="Right">
            <TextBlock x:Name="InstallModeBadge"
                       Foreground="White"
                       FontWeight="SemiBold"
                       Text="Machine Install" />
          </Border>
          <TextBlock Text="Managed Configuration"
                     Foreground="#FF6B35"
                     FontWeight="SemiBold"
                     FontSize="12"
                     Margin="0,16,0,0"
                     HorizontalAlignment="Right" />
          <Border Background="#1E293B"
                  BorderBrush="#334155"
                  BorderThickness="1"
                  CornerRadius="10"
                  Padding="14,12"
                  Margin="0,8,0,0">
            <TextBlock x:Name="ConfigPathText"
                       Foreground="#E2E8F0"
                       FontSize="13"
                       LineHeight="18"
                       TextAlignment="Left"
                       TextWrapping="Wrap" />
          </Border>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Main Scrollable Section -->
    <ScrollViewer Grid.Row="1"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  CanContentScroll="False">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Provider Presets -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="Provider Presets"
                         FontSize="18"
                         FontWeight="SemiBold"
                         Foreground="#F8FAFC" />
              <TextBlock Text="Apply a curated provider pack, then fine-tune blocked hosts and desktop processes below."
                         Margin="0,6,0,14"
                         Foreground="#94A3B8" />
              <ComboBox x:Name="PresetComboBox"
                        Width="320"
                        Height="34"
                        HorizontalAlignment="Left" />
            </StackPanel>
            <Button x:Name="AddPresetButton"
                    Grid.Column="1"
                    Width="136"
                    Height="38"
                    Margin="18,26,0,0"
                    VerticalAlignment="Top"
                    Content="Add Provider"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="AddPresetButton_Click" />
          </Grid>
        </Border>

        <!-- Lists for Blocked Items -->
        <Grid Grid.Row="1">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <!-- Blocked Hosts -->
          <Border Grid.Column="0" Style="{StaticResource CardStyle}">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>
              <StackPanel>
                <TextBlock Text="Blocked Websites / Hosts"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#F8FAFC" />
                <TextBlock Text="These hosts are denied by Ulti Guard browser policy and extension enforcement as soon as the managed browser applies policy."
                           Margin="0,6,0,14"
                           Foreground="#94A3B8"
                           TextWrapping="Wrap" />
              </StackPanel>
              <ListBox x:Name="BlockedHostsListBox"
                       Grid.Row="1"
                       MinHeight="240"
                       MaxHeight="360"
                       BorderThickness="1"
                       SelectionMode="Extended" />
              <StackPanel Grid.Row="2" Margin="0,16,0,0">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBox x:Name="BlockedHostTextBox"
                           Grid.Column="0"
                           Height="36"
                           MinWidth="280"
                           Padding="12,7"
                           KeyDown="BlockedHostTextBox_KeyDown" />
                  <Button x:Name="AddHostButton"
                          Grid.Column="1"
                          Width="96"
                          Margin="12,0,0,0"
                          Content="Add Host"
                          Style="{StaticResource PrimaryButtonStyle}"
                          Click="AddHostButton_Click" />
                  <Button x:Name="RemoveHostButton"
                          Grid.Column="2"
                          Width="88"
                          Margin="12,0,0,0"
                          Content="Remove"
                          Click="RemoveHostButton_Click" />
                </Grid>
                <TextBlock Text="Examples: grok.com, gemini.google.com, chat.deepseek.com"
                           Margin="0,10,0,0"
                           Foreground="#64748B" />
              </StackPanel>
            </Grid>
          </Border>

          <!-- Blocked Processes -->
          <Border Grid.Column="2" Style="{StaticResource CardStyle}">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>
              <StackPanel>
                <TextBlock Text="Blocked Desktop Processes"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#F8FAFC" />
                <TextBlock Text="These process names are terminated while Ulti Guard is in active Claude protection mode."
                           Margin="0,6,0,14"
                           Foreground="#94A3B8"
                           TextWrapping="Wrap" />
              </StackPanel>
              <ListBox x:Name="BlockedProcessesListBox"
                       Grid.Row="1"
                       MinHeight="240"
                       MaxHeight="360"
                       BorderThickness="1"
                       SelectionMode="Extended" />
              <StackPanel Grid.Row="2" Margin="0,16,0,0">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBox x:Name="BlockedProcessTextBox"
                           Grid.Column="0"
                           Height="36"
                           MinWidth="280"
                           Padding="12,7"
                           KeyDown="BlockedProcessTextBox_KeyDown" />
                  <Button x:Name="AddProcessButton"
                          Grid.Column="1"
                          Width="112"
                          Margin="12,0,0,0"
                          Content="Add Process"
                          Style="{StaticResource PrimaryButtonStyle}"
                          Click="AddProcessButton_Click" />
                  <Button x:Name="RemoveProcessButton"
                          Grid.Column="2"
                          Width="88"
                          Margin="12,0,0,0"
                          Content="Remove"
                          Click="RemoveProcessButton_Click" />
                </Grid>
                <TextBlock Text="Examples: Cursor, Ollama, LM Studio, ChatGPT"
                           Margin="0,10,0,0"
                           Foreground="#64748B" />
              </StackPanel>
            </Grid>
          </Border>
        </Grid>

        <!-- PII Detection & Prevention Settings -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,0,0,18">
          <StackPanel>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="PII Detection &amp; Prevention Settings"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#F8FAFC" />
                <TextBlock Text="Configure active scanning for Personally Identifiable Information (PII) like emails, SSNs, credit cards, and API keys."
                           Margin="0,6,0,14"
                           Foreground="#94A3B8"
                           TextWrapping="Wrap" />
              </StackPanel>
              <CheckBox x:Name="PiiEnabledCheckBox"
                        Grid.Column="1"
                        Content="Enable PII Scanning"
                        Style="{StaticResource SwitchCheckBoxStyle}"
                        Foreground="#F8FAFC"
                        FontWeight="SemiBold"
                        VerticalAlignment="Center"
                        Checked="PiiEnabledCheckBox_Checked"
                        Unchecked="PiiEnabledCheckBox_Checked" />
            </Grid>

            <Separator Background="#334155" Margin="0,4,0,16" />

            <!-- PII Settings Container -->
            <StackPanel x:Name="PiiSettingsPanel">
              <!-- Confidence Score Section -->
              <TextBlock Text="Confidence Score"
                         FontSize="14"
                         FontWeight="SemiBold"
                         Foreground="#F8FAFC"
                         Margin="0,0,0,6" />
              <TextBox x:Name="PiiConfidenceTextBox"
                       Height="36"
                       Text="0.35"
                       Padding="12,7"
                       Margin="0,0,0,4" />
              <TextBlock Text="Minimum confidence score to trigger PII detection (0 to 1)"
                         Foreground="#94A3B8"
                         FontSize="12"
                         Margin="0,0,0,20" />

              <!-- Current Functionality Section -->
              <TextBlock Text="Current Functionality"
                         FontSize="14"
                         FontWeight="SemiBold"
                         Foreground="#F8FAFC"
                         Margin="0,0,0,10" />
              
              <!-- 2x3 Grid for PII Actions -->
              <Grid Margin="0,0,0,10">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="18" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="18" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Row 1 -->
                <RadioButton x:Name="PiiActionRedact"
                             Grid.Row="0" Grid.Column="0"
                             GroupName="PiiActionGroup"
                             Content="Redact"
                             Style="{StaticResource PiiRadioButtonStyle}"
                             Margin="0,0,0,14" />
                <RadioButton x:Name="PiiActionMask"
                             Grid.Row="0" Grid.Column="2"
                             GroupName="PiiActionGroup"
                             Content="Mask"
                             Style="{StaticResource PiiRadioButtonStyle}"
                             Margin="0,0,0,14" />
                <RadioButton x:Name="PiiActionReplace"
                             Grid.Row="0" Grid.Column="4"
                             GroupName="PiiActionGroup"
                             Content="Replace"
                             Style="{StaticResource PiiRadioButtonStyle}"
                             Margin="0,0,0,14" />

                <!-- Row 2 -->
                <RadioButton x:Name="PiiActionHash"
                             Grid.Row="1" Grid.Column="0"
                             GroupName="PiiActionGroup"
                             Content="Hash"
                             Style="{StaticResource PiiRadioButtonStyle}" />
                <RadioButton x:Name="PiiActionKeep"
                             Grid.Row="1" Grid.Column="2"
                             GroupName="PiiActionGroup"
                             Content="Keep"
                             Style="{StaticResource PiiRadioButtonStyle}" />
                <RadioButton x:Name="PiiActionBlock"
                             Grid.Row="1" Grid.Column="4"
                             GroupName="PiiActionGroup"
                             Content="Block"
                             Style="{StaticResource PiiRadioButtonStyle}" />
              </Grid>
              <TextBlock Text="Action to take when PII is detected globally."
                         Foreground="#94A3B8"
                         FontSize="12"
                         Margin="0,4,0,10" />
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>
    </ScrollViewer>

    <!-- Footer Controls / Status Bar -->
    <Border Grid.Row="2"
            Background="#0F172A"
            BorderBrush="#334155"
            BorderThickness="1"
            CornerRadius="16"
            Padding="18"
            Margin="0,18,0,0">
      <StackPanel>
        <TextBlock x:Name="StatusTextBlock"
                   Foreground="#F1F5F9"
                   FontWeight="SemiBold"
                   Text="Ready."
                   TextWrapping="Wrap" />
        <WrapPanel HorizontalAlignment="Right"
                   Margin="0,16,0,0">
          <Button x:Name="ChangePasswordButton"
                  Width="154"
                  Height="40"
                  Margin="0,0,12,12"
                  Content="Change Password"
                  Click="ChangePasswordButton_Click" />
          <Button x:Name="ReloadButton"
                  Width="90"
                  Height="40"
                  Margin="0,0,12,12"
                  Content="Reload"
                  Click="ReloadButton_Click" />
          <Button x:Name="SaveButton"
                  Width="136"
                  Height="40"
                  Margin="0,0,12,12"
                  Content="Save and Apply"
                  Style="{StaticResource PrimaryButtonStyle}"
                  Click="SaveButton_Click" />
          <Button Width="80"
                  Height="40"
                  Margin="0,0,0,12"
                  Content="Close"
                  Click="CloseButton_Click" />
        </WrapPanel>
      </StackPanel>
    </Border>
  </Grid>
</Window>
