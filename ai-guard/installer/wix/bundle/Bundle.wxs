<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal">
  <Bundle
    Name="Ulti Guard Setup"
    Manufacturer="WinInfoSoft"
    Version="$(var.BundleVersion)"
    UpgradeCode="{ED8B1573-CA4E-4347-A0B5-9AE31644D43E}">

    <BootstrapperApplication>
      <bal:WixStandardBootstrapperApplication Theme="hyperlinkLicense" LicenseUrl="" />
    </BootstrapperApplication>

    <Chain>
      <MsiPackage SourceFile="$(var.MsiPath)" Visible="no" />
    </Chain>
  </Bundle>
</Wix>
