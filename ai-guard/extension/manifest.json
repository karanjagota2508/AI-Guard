{
  "manifest_version": 3,
  "name": "AI Guard Agent",
  "version": "1.0.0",
  "description": "Protect Claude sessions with prompt scanning and LLM isolation.",
  "incognito": "split",
  "key": "",
  "minimum_chrome_version": "120",
  "update_url": "http://127.0.0.1:48555/update.xml",
  "permissions": [
    "nativeMessaging",
    "storage",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://perplexity.ai/*",
    "https://www.perplexity.ai/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "AI Guard Agent"
  }
}
